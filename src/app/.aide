  progressive-disclosure.md -> /docs/progressive-disclosure
  agent-readable-code.md    -> /docs/agent-readable-code
  automated-qa.md           -> /docs/automated-qa
  cascading-alignment.md    -> /docs/cascading-alignment
.claude/
  agents/aide/
    aide-spec-writer.md     -> /agents/aide-spec-writer
    aide-domain-expert.md   -> /agents/aide-domain-expert
    aide-strategist.md      -> /agents/aide-strategist
    aide-architect.md       -> /agents/aide-architect
    aide-implementor.md     -> /agents/aide-implementor
    aide-qa.md              -> /agents/aide-qa
    aide-aligner.md         -> /agents/aide-aligner
    aide-auditor.md         -> /agents/aide-auditor
    aide-explorer.md        -> /agents/aide-explorer
  commands/aide/
    aide.md                 -> /commands/aide
    spec.md                 -> /commands/aide-spec
    research.md             -> /commands/aide-research
    synthesize.md           -> /commands/aide-synthesize
    plan.md                 -> /commands/aide-plan
    build.md                -> /commands/aide-build
    qa.md                   -> /commands/aide-qa
    fix.md                  -> /commands/aide-fix
